# ============================================
# ALPACA TRADING BOT — API YAPILANDIRMASI
# ============================================
# Sign up for free at https://alpaca.markets
# Paper Trading -> API Keys -> Generate
# Live Trading -> API Keys -> Generate (ayri key!)

# --- LIVE (GERCEK PARA) API Keys ---
ALPACA_LIVE_API_KEY=your_live_api_key_here
ALPACA_LIVE_SECRET_KEY=your_live_secret_key_here

# --- PAPER (TEST / SHORT BOT) API Keys ---
ALPACA_PAPER_API_KEY=your_paper_api_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key_here

# Geriye uyumluluk (lokal calistirma icin — Docker disinda)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# TRADING_MODE: "paper" veya "live"
TRADING_MODE=paper

# --- HABER & VERI API'LERI ---
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
MARKETAUX_TOKEN=your_marketaux_token_here
